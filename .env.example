# ==============================================================================
# CONFIGURACIÓN DEL ENTORNO TEXT-TO-SQL
# ==============================================================================

# Entorno de la aplicación (development, production)
APP_ENV=development

# Puerto donde se servirá la API y el Frontend
APP_PORT=8000

# ==============================================================================
# CONFIGURACIÓN DEL MODELO DE IA
# ==============================================================================

# Proveedor activo por defecto. Opciones recomendadas: mock, openai, deepseek, gemini
MODEL_PROVIDER=deepseek

# Nombre del modelo a utilizar. Ejemplos: 
# openai -> gpt-4o, gpt-4o-mini
# deepseek -> deepseek-chat, deepseek-v4-flash
# gemini -> gemini-2.5-flash
# mock -> demo-sql-v1
MODEL_NAME=deepseek-v4-flash

# ------------------------------------------------------------------------------
# CLAVES DE API (Rellena solo la del proveedor que vayas a utilizar)
# ------------------------------------------------------------------------------

# OpenAI
OPENAI_API_KEY=tu_api_key_de_openai_aqui
OPENAI_BASE_URL=

# DeepSeek
DEEPSEEK_API_KEY=tu_api_key_de_deepseek_aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Gemini
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# ==============================================================================
# CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL
# ==============================================================================

# IMPORTANTE: Al usar docker-compose, POSTGRES_HOST debe ser el nombre del servicio (db)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=text2sql_demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
